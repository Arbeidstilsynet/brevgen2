{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>Arbeidstilsynet/renovate-config"],
  "reviewersFromCodeOwners": true,
  "packageRules": [
    {
      "matchFileNames": ["apps/preview-web/package.json", "apps/api/package.json"],
      "extends": ["config:js-app"]
    },
    {
      "matchPackageNames": ["puppeteer", "puppeteer-core"],
      "matchManagers": ["npm"],
      "automerge": false,
      "description": "Avoid automerging puuppeteer patches to preserve compatibility with specific Chromium versions"
    },
    {
      "matchManagers": ["pre-commit"],
      "matchPackageNames": "oxc-project/mirrors-oxlint",
      "automerge": false,
      "description": "Avoid automerging oxlint updates until Windows OOM issue is resolved"
    }
  ]
}
