{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "reviewers": ["Produkt Plattform - Utviklere"],
  "packageRules": [
    {
      "matchFileNames": ["apps/preview-web/package.json", "apps/api/package.json"],
      "extends": ["config:js-app"]
    },
    {
      "matchPackageNames": ["puppeteer", "puppeteer-core"],
      "matchManagers": ["npm"],
      "automerge": false,
      "description": "Avoid automerging puuppeteer patches to preserve compatibility with specific Chromium versions"
    }
  ]
}
