{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config vite.dev.config.ts",
    "build": "del-cli ./dist && tsup server.ts",
    "test": "vitest run --coverage lib",
    "test:integration": "vitest run integration-tests",
    "test:load": "npx --yes tsx load-tests/run.ts",
    "test:load:analyze": "npx --yes tsx load-tests/analyze.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@at/document-templates": "workspace:*",
    "@at/dynamic-markdown": "workspace:*",
    "@fastify/cors": "11.1.0",
    "@fastify/jwt": "10.0.0",
    "@fastify/swagger": "9.5.2",
    "@fastify/swagger-ui": "5.2.3",
    "@repo/shared-types": "workspace:^",
    "dotenv": "17.2.3",
    "fastify": "5.6.2",
    "fastify-type-provider-zod": "6.1.0",
    "jwks-rsa": "3.2.0",
    "marked": "16.4.1",
    "p-limit": "7.2.0",
    "pdf-lib": "1.17.1",
    "pino-pretty": "13.1.2",
    "puppeteer-core": "24.27.0",
    "sanitize-html": "2.17.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "9.39.0",
    "@repo/typescript-config": "workspace:^",
    "@types/node": "24.9.2",
    "@types/sanitize-html": "2.16.0",
    "del-cli": "7.0.0",
    "eslint": "9.39.0",
    "globals": "16.5.0",
    "pdf-text-reader": "5.1.0",
    "pdf-visual-diff": "0.14.0",
    "puppeteer": "24.27.0",
    "testcontainers": "11.7.2",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.4",
    "vite": "7.1.12",
    "vite-plugin-node": "7.0.0",
    "vitest": "4.0.14"
  }
}
