{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.dev.config.ts",
    "prebuild": "npx --yes rimraf dist",
    "build": "tsup lambda/index.ts && npx --yes cpy-cli fonts dist",
    "build:docker": "npm run prebuild && tsup server.ts",
    "test": "vitest run --coverage lib lambda",
    "test:integration": "vitest run integration-tests",
    "test:load": "npx --yes tsx load-tests/run.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@at/document-templates": "workspace:*",
    "@at/dynamic-markdown": "workspace:*",
    "@fastify/cors": "11.0.1",
    "@repo/shared-types": "workspace:^",
    "@sparticuz/chromium": "133.0.0",
    "fastify": "5.2.2",
    "marked": "15.0.9",
    "p-limit": "6.2.0",
    "pdf-lib": "1.17.1",
    "puppeteer-core": "24.3.1",
    "sanitize-html": "2.15.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "9.24.0",
    "@repo/typescript-config": "workspace:^",
    "@types/aws-lambda": "8.10.149",
    "@types/node": "22.14.1",
    "@types/sanitize-html": "2.15.0",
    "eslint": "9.24.0",
    "globals": "16.0.0",
    "pdf-text-reader": "5.1.0",
    "pdf-visual-diff": "0.14.0",
    "prettier": "3.5.3",
    "puppeteer": "24.3.1",
    "rimraf": "6.0.1",
    "testcontainers": "10.24.2",
    "tsup": "8.4.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.29.1",
    "vite": "6.3.2",
    "vite-plugin-node": "5.0.1",
    "vitest": "3.1.2"
  }
}
