{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.dev.config.ts",
    "prebuild": "del-cli ./dist",
    "build": "tsup lambda/index.ts && npx --yes cpy-cli fonts dist",
    "build:docker": "npm run prebuild && tsup server.ts",
    "test": "vitest run --coverage lib lambda",
    "test:integration": "vitest run integration-tests",
    "test:load": "npx --yes tsx load-tests/run.ts",
    "test:load:analyze": "npx --yes tsx load-tests/analyze.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@at/document-templates": "workspace:*",
    "@at/dynamic-markdown": "workspace:*",
    "@fastify/cors": "11.1.0",
    "@fastify/jwt": "10.0.0",
    "@repo/shared-types": "workspace:^",
    "@sparticuz/chromium": "138.0.2",
    "dotenv": "17.2.3",
    "fastify": "5.6.1",
    "jwks-rsa": "3.2.0",
    "marked": "16.3.0",
    "p-limit": "7.1.1",
    "pdf-lib": "1.17.1",
    "puppeteer-core": "24.23.0",
    "sanitize-html": "2.17.0",
    "zod": "4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "9.37.0",
    "@repo/typescript-config": "workspace:^",
    "@types/aws-lambda": "8.10.155",
    "@types/node": "24.7.0",
    "@types/sanitize-html": "2.16.0",
    "del-cli": "7.0.0",
    "eslint": "9.37.0",
    "globals": "16.4.0",
    "pdf-text-reader": "5.1.0",
    "pdf-visual-diff": "0.14.0",
    "puppeteer": "24.23.0",
    "testcontainers": "11.7.1",
    "tsup": "8.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.45.0",
    "vite": "7.1.9",
    "vite-plugin-node": "7.0.0",
    "vitest": "3.2.4"
  }
}
