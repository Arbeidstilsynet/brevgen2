{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.dev.config.ts",
    "prebuild": "npx --yes rimraf dist",
    "build": "tsup lambda/index.ts && npx --yes cpy-cli fonts dist",
    "build:docker": "npm run prebuild && tsup server.ts",
    "test": "vitest run --coverage lib",
    "test:integration": "vitest run integration-tests",
    "test:load": "npx --yes tsx load-tests/run.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@at/document-templates": "workspace:*",
    "@at/dynamic-markdown": "workspace:*",
    "@sparticuz/chromium": "133.0.0",
    "get-port": "7.1.0",
    "marked": "15.0.7",
    "pdf-lib": "1.17.1",
    "puppeteer-core": "24.3.1",
    "sanitize-html": "2.15.0"
  },
  "devDependencies": {
    "@eslint/js": "9.23.0",
    "@repo/typescript-config": "workspace:^",
    "@types/aws-lambda": "8.10.148",
    "@types/express": "4.17.21",
    "@types/node": "22.13.14",
    "@types/sanitize-html": "2.15.0",
    "eslint": "9.23.0",
    "express": "4.21.2",
    "globals": "16.0.0",
    "pdf-text-reader": "5.1.0",
    "pdf-visual-diff": "0.14.0",
    "prettier": "3.5.3",
    "puppeteer": "24.3.1",
    "rimraf": "6.0.1",
    "testcontainers": "10.23.0",
    "tsup": "8.4.0",
    "typescript": "5.8.2",
    "typescript-eslint": "8.28.0",
    "vite": "6.2.4",
    "vite-plugin-node": "5.0.0",
    "vitest": "3.0.9"
  }
}
