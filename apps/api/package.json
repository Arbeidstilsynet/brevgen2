{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config vite.dev.config.ts",
    "build": "del-cli ./dist && tsup server.ts",
    "test": "vitest run --coverage lib",
    "test:integration": "vitest run integration-tests",
    "test:load": "npx --yes tsx load-tests/run.ts",
    "test:load:analyze": "npx --yes tsx load-tests/analyze.ts",
    "lint": "eslint .",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@at/document-templates": "workspace:*",
    "@at/dynamic-markdown": "workspace:*",
    "@fastify/cors": "11.2.0",
    "@fastify/jwt": "10.0.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "@repo/shared-types": "workspace:^",
    "dotenv": "17.3.1",
    "fastify": "5.7.4",
    "fastify-type-provider-zod": "6.1.0",
    "jwks-rsa": "3.2.2",
    "marked": "16.4.2",
    "p-limit": "7.3.0",
    "pdf-lib": "1.17.1",
    "pino-pretty": "13.1.3",
    "puppeteer-core": "24.37.5",
    "sanitize-html": "2.17.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@repo/typescript-config": "workspace:^",
    "@types/node": "24.10.13",
    "@types/sanitize-html": "2.16.0",
    "@typescript/native-preview": "7.0.0-dev.20260224.1",
    "del-cli": "7.0.0",
    "eslint": "9.39.3",
    "globals": "17.3.0",
    "pdf-text-reader": "5.1.1",
    "pdf-visual-diff": "0.15.2",
    "puppeteer": "24.37.5",
    "testcontainers": "11.12.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.1",
    "vite-plugin-node": "7.0.0",
    "vitest": "4.0.18"
  }
