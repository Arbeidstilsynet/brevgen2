{
  "name": "felles-brevgenerator-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "pnpm --filter preview-web dev",
    "test": "turbo test",
    "test:integration": "pnpm --filter api test:integration",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prek": "prek run --all-files",
    "circular": "pnpx madge --circular --extensions \"js,jsx,ts,tsx\" --exclude \".next|dist\" .",
    "docker:api": "pnpm docker:api:build && pnpm docker:api:run",
    "docker:api:build": "docker build -f apps/api/Dockerfile -t brevgenerator2-api:test .",
    "docker:api:run": "docker run --rm --name brevgenerator2-api -p 4000:4000 -e DANGEROUS_DISABLE_AUTH=true brevgenerator2-api:test",
    "docker:api:run:auth": "docker run --rm --name brevgenerator2-api -p 4000:4000 -e AZURE_APPLICATION_ID=079a726c-1419-4907-9aeb-e230f700e22a brevgenerator2-api:test",
    "docker:api:stop": "docker stop brevgenerator2-api",
    "docker:web:build": "docker build -f apps/preview-web/Dockerfile -t brevgenerator2-web:test .",
    "docker:web:run": "docker run --rm --name brevgenerator2-web -p 3000:3000 brevgenerator2-web:test",
    "docker:web:stop": "docker stop brevgenerator2-web"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@typescript/native-preview": "7.0.0-dev.20260404.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "oxfmt": "0.44.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.19.0",
    "turbo": "2.9.3",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0"
}
