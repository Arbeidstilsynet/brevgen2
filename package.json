{
  "name": "felles-brevgenerator-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css,scss}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,css,scss}\"",
    "circular": "npx --yes madge --circular --extensions \"js,jsx,ts,tsx\" --exclude \".next|dist\" .",
    "docker:api:build": "docker build -f apps/api/Dockerfile -t brevgenerator2-api:test .",
    "docker:api:run": "docker run --rm -p 4000:4000 -e DANGEROUS_DISABLE_AUTH=true brevgenerator2-api:test",
    "docker:api:run:auth": "docker run --rm -p 4000:4000 -e AZURE_APPLICATION_ID=079a726c-1419-4907-9aeb-e230f700e22a brevgenerator2-api:test",
    "docker:web:build": "docker build -f apps/preview-web/Dockerfile -t brevgenerator2-web:test .",
    "docker:web:run": "docker run --rm -p 3000:3000 brevgenerator2-web:test"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "prettier": "3.6.2",
    "turbo": "2.5.8",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.17.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "puppeteer"
    ],
    "overrides": {
      "tar-fs@>=3.0.0 <3.1.1": ">=3.1.1",
      "pino@>=9.0.0 <9.13.1": "9.13.1"
    }
  }
}
