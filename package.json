{
  "name": "felles-brevgenerator-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css,scss}\"",
    "check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,css,scss}\"",
    "circular": "npx --yes madge --circular --extensions \"js,jsx,ts,tsx\" --exclude \".next|dist\" ."
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "prettier": "3.5.1",
    "turbo": "2.4.2",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.5",
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "postcss": "8.5.2"
    }
  }
}
