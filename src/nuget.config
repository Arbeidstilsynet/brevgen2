<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="Skjemamottak.Felles" value="https://pkgs.dev.azure.com/Atil-utvikling/Produkter%20og%20Tjenester/_packaging/Skjemamottak.Felles/nuget/v3/index.json" />
  </packageSources>

  <packageSourceCredentials>
    <Skjemamottak.Felles>
      <add key="Username" value="any" />
      <add key="ClearTextPassword" value="%VSS_NUGET_ACCESSTOKEN%" />
    </Skjemamottak.Felles>
  </packageSourceCredentials>
</configuration>
